   "source": [
    "n = int(input())\n",
    "a = list(map(int, input().split()))\n",
    "b = list(map(int, input().split()))\n",
    "a.sort()\n",
    "\n",
    "result = 0\n",
    "\n",
    "while b:\n",
    "    for i in range(len(a)):\n",
    "       max_b = max(b)\n",
    "       result += a[i] * max_b\n",
    "       b.remove(max_b)\n",
    "\n",
    "print(result)"
   ]
  }
 ],
