    "# N = int(input())\n",
    "N = 7 \n",
    "arr =  [7, 8, 1, 2, 3, 4, 5]\n",
    "\n",
    "\n",
    "cnt = 0\n",
    "results = []\n",
    "for i in range(N-1):\n",
    "    if (arr[i] * arr[i+1]) != abs(arr[i] * arr[i+1]):\n",
    "        cnt = 0\n",
    "    cnt += 1\n",
    "    results.append(cnt)\n",
    "\n",
    "print(results)\n",
    "print(max(results))"
   ]
  }
